# Mems Configuration Example
# Copy this file to .env and fill in actual values

# ===================
# Database
# ===================
# Relative SQLite paths are resolved from the project root.
# Leave this as-is for local development, or override with Postgres/another DB.
DATABASE_URL=sqlite:///mems.db

# ===================
# Redis Configuration
# ===================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ===================
# Qdrant Configuration
# ===================
# Optional full URL. If set, it takes precedence over host/port.
# Recommended server version for the current SDK path: Qdrant 1.15+
QDRANT_URL=
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=
QDRANT_TIMEOUT=30
QDRANT_HTTPS=false
QDRANT_PREFER_GRPC=false

# ===================
# Embedding Model Configuration
# ===================
# Options: sentence-transformers, openai
EMBEDDING_PROVIDER=sentence-transformers
# Used when provider=sentence-transformers
SENTENCE_TRANSFORMERS_MODEL=BAAI/bge-small-zh-v1.5
# Used when provider=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_API_KEY=

# ===================
# LLM Distillation Configuration (OpenAI-compatible)
# ===================
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT=300

# ===================
# Application Configuration
# ===================
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ===================
# Archive Configuration
# ===================
ARCHIVE_DAYS=30
ARCHIVE_STORAGE_PATH=storage/l3_archive

# ===================
# Scheduler Configuration
# ===================
# Enable scheduler
SCHEDULER_ENABLED=true
# Distillation cron (hour)
DISTILL_CRON_HOUR=2
# Distillation cron (minute)
DISTILL_CRON_MINUTE=0
# Distillation threshold: scheduled distill currently checks this threshold before processing
DISTILL_THRESHOLD=100
# Distillation batch size
DISTILL_BATCH_SIZE=50
# Archive cron (hour)
ARCHIVE_CRON_HOUR=3
# Archive cron (minute)
ARCHIVE_CRON_MINUTE=0

# ===================
# L0 Auto Sync Configuration
# ===================
# Reserved toggle. Current runtime write paths still persist to L1 directly.
L0_AUTO_SYNC_L1=true
# L0 default TTL (seconds)
L0_DEFAULT_TTL_SECONDS=1800

# ===================
# Memory Identity Recommendations
# ===================
# For multi-user agents, pass tenant_id/user_id/scope at the API layer.
# These are request-level identity fields, not environment variables.
# Recommended defaults:
# - single-user app: tenant_id=default, scope=private
# - multi-user app: always pass user_id explicitly
