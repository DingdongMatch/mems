# Mems Configuration Example
# Copy this file to .env and fill in actual values

# ===================
# Database
# ===================
DATABASE_URL=sqlite:///mems.db

# ===================
# Redis Configuration
# ===================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ===================
# Qdrant Configuration
# ===================
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_TIMEOUT=30

# ===================
# Embedding Model Configuration
# ===================
# Options: sentence-transformers, openai
EMBEDDING_PROVIDER=sentence-transformers
# Used when provider=sentence-transformers
SENTENCE_TRANSFORMERS_MODEL=BAAI/bge-small-zh-v1.5

# ===================
# LLM Distillation Configuration (OpenAI/DashScope)
# ===================
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ===================
# Application Configuration
# ===================
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ===================
# Archive Configuration
# ===================
ARCHIVE_DAYS=30
ARCHIVE_STORAGE_PATH=storage/l3_archive

# ===================
# Scheduler Configuration
# ===================
# Enable scheduler
SCHEDULER_ENABLED=true
# Distillation cron (hour)
DISTILL_CRON_HOUR=2
# Distillation cron (minute)
DISTILL_CRON_MINUTE=0
# Distillation threshold: triggers when undiluted L1 records exceed this
DISTILL_THRESHOLD=100
# Distillation batch size
DISTILL_BATCH_SIZE=50
# Archive cron (hour)
ARCHIVE_CRON_HOUR=3
# Archive cron (minute)
ARCHIVE_CRON_MINUTE=0

# ===================
# L0 Auto Sync Configuration
# ===================
# Auto sync to L1 when writing to L0
L0_AUTO_SYNC_L1=true
# L0 default TTL (seconds)
L0_DEFAULT_TTL_SECONDS=1800